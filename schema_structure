CREATE OR REPLACE VIEW public.active_communities AS
 SELECT c.id,
    c.community_name,
    c.location,
    c.contact_person,
    c.phone_number,
    c.email,
    c.description,
    c.established_year,
    c.member_count,
    c.photo_type,
    c.registration_status,
    c.approved_by,
    c.approved_at,
    c.coordinates,
    c.area_size,
    c.mangrove_species,
    c.conservation_status,
    c.website_url,
    c.social_media,
    c.created_at,
    c.updated_at,
    (((u.first_name)::text || ' '::text) || (u.last_name)::text) AS approved_by_name,
    count(cm.id) AS member_count_actual
   FROM ((public.communities c
     LEFT JOIN public.users u ON ((c.approved_by = u.id)))
     LEFT JOIN public.community_members cm ON (((c.id = cm.community_id) AND (cm.is_active = true))))
  WHERE ((c.registration_status)::text = 'approved'::text)
  GROUP BY c.id, u.first_name, u.last_name;



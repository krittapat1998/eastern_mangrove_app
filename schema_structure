-- TOC entry 231 (class 1259 OID 17413)
-- Name: upcoming_activities; Type: VIEW; Schema: public; Owner: mydb_kritdev_user
--

CREATE VIEW public.upcoming_activities AS
 SELECT ca.id,
    ca.community_id,
    ca.created_by,
    ca.title,
    ca.description,
    ca.activity_type,
    ca.start_date,
    ca.end_date,
    ca.location,
    ca.coordinates,
    ca.max_participants,
    ca.current_participants,
    ca.status,
    ca.budget,
    ca.funding_source,
    ca.impact_metrics,
    ca.photos,
    ca.documents,
    ca.tags,
    ca.created_at,
    ca.updated_at,
    c.community_name,
    c.location AS community_location,
    (((u.first_name)::text || ' '::text) || (u.last_name)::text) AS created_by_name
   FROM ((public.community_activities ca
     JOIN public.communities c ON ((ca.community_id = c.id)))
     LEFT JOIN public.users u ON ((ca.created_by = u.id)))
  WHERE ((ca.start_date > now()) AND ((ca.status)::text = ANY ((ARRAY['planned'::character varying, 'ongoing'::character varying])::text[])))
  ORDER BY ca.start_date;


ALTER VIEW public.upcoming_activities OWNER TO mydb_kritdev_user;

--
-- TOC entry 232 (class 1259 OID 17418)
-- Name: user_statistics; Type: VIEW; Schema: public; Owner: mydb_kritdev_user
--

CREATE VIEW public.user_statistics AS
 SELECT user_type,
    count(*) AS total_count,
    count(
        CASE
            WHEN (is_active = true) THEN 1
            ELSE NULL::integer
        END) AS active_count,
    count(
        CASE
            WHEN (email_verified = true) THEN 1
            ELSE NULL::integer
        END) AS verified_count
   FROM public.users
  GROUP BY user_type;


ALTER VIEW public.user_statistics OWNER TO mydb_kritdev_user;

